{
  "manifest_version": 3,
  "minimum_chrome_version": "116",
  "name": "LearnNote 当前视频助手",
  "version": "0.1.39",
  "description": "识别当前正在播放的视频，并安全交接到本机 LearnNote 客户端。",
  "homepage_url": "https://hurry060215-tech.github.io/learnnote-assistant/",
  "permissions": [
    "activeTab",
    "tabs",
    "scripting",
    "webRequest",
    "webNavigation",
    "cookies",
    "storage",
    "alarms",
    "sidePanel",
    "downloads"
  ],
  "host_permissions": [
    "<all_urls>",
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "打开 LearnNote 当前视频助手",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["page_hook.js"],
      "run_at": "document_start",
      "all_frames": true,
      "match_about_blank": true,
      "match_origin_as_fallback": true,
      "world": "MAIN"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true,
      "match_about_blank": true,
      "match_origin_as_fallback": true
    }
  ]
}
