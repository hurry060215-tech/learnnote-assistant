{
  "manifest_version": 3,
  "name": "LearnNote 当前页助手",
  "version": "0.1.0",
  "description": "当前页视频直取、本地视频上传、转写与图文总结。",
  "permissions": [
    "activeTab",
    "tabs",
    "scripting",
    "webRequest",
    "cookies",
    "storage",
    "sidePanel"
  ],
  "host_permissions": [
    "<all_urls>",
    "http://127.0.0.1:8765/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "LearnNote 当前页助手"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
