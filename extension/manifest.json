{
  "manifest_version": 3,
  "minimum_chrome_version": "116",
  "name": "LearnNote 当前页学习助手",
  "version": "0.1.35",
  "description": "直接读取当前页视频、本地视频上传、转写、视觉切片与图文总结。",
  "permissions": [
    "activeTab",
    "tabs",
    "scripting",
    "webRequest",
    "webNavigation",
    "cookies",
    "storage",
    "alarms",
    "sidePanel",
    "downloads"
  ],
  "host_permissions": [
    "<all_urls>",
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "打开 LearnNote 当前页学习助手"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["page_hook.js"],
      "run_at": "document_start",
      "all_frames": true,
      "match_about_blank": true,
      "match_origin_as_fallback": true,
      "world": "MAIN"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": true,
      "match_about_blank": true,
      "match_origin_as_fallback": true
    }
  ]
}
